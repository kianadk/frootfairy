{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "outputDirectory": "build",
    "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    },
    { "source": "/api/(.*)", "destination": "/api/server.js" }],
    "builds": [
      {
        "src": "api/server.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/api(.*)",
        "dest": "api/server.js"
      }
    ]
}